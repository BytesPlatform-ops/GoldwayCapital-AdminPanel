# =============================================================================
# Goldway Capital — root env template (copy to .env). NEVER commit real secrets.
# Single Next.js app (public site + admin + /api routes). Copy to .env.
# Defaults keep GHL / WordPress / social / email in MOCK mode — safe to run as-is.
# =============================================================================

# ---- App URLs -------------------------------------------------------------
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000/admin
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Comma-separated origins the API accepts (the Next.js web app).
CORS_ORIGINS=http://localhost:3000

# ---- Database (PostgreSQL) ------------------------------------------------
# Option A — SUPABASE (recommended for shared/prod). Get the strings from
#   Supabase Dashboard → Project → Connect → ORMs → Prisma. Paste your DB password.
#   DATABASE_URL = transaction-mode pooler (runtime, 6543, pgbouncer=true)
#   DIRECT_URL   = session-mode pooler (migrations, 5432)
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:[YOUR-PASSWORD]@aws-1-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:[YOUR-PASSWORD]@aws-1-<REGION>.pooler.supabase.com:5432/postgres"
# Option B — LOCAL DOCKER (offline dev; matches docker-compose.yml, host port 5433):
# DATABASE_URL="postgresql://goldway:goldway@localhost:5433/goldway?schema=public"
# DIRECT_URL="postgresql://goldway:goldway@localhost:5433/goldway?schema=public"

# ---- Auth -----------------------------------------------------------------
JWT_SECRET=change-me-in-production-min-32-chars-secret-value
SESSION_SECRET=change-me-in-production-another-long-random-secret
# Shared secret the public site sends with form posts (x-goldway-key header).
LEAD_API_INGEST_KEY=change-me-shared-with-website

# ---- GoHighLevel CRM ------------------------------------------------------
GHL_ENABLED=false
GHL_MOCK_MODE=true
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=
GHL_PIPELINE_ID=
GHL_STAGE_NEW_ID=
GHL_STAGE_CONTACTED_ID=
GHL_STAGE_APPOINTMENT_SET_ID=
GHL_STAGE_CLOSED_ID=
GHL_WEBHOOK_SECRET=
# Confirmation workflow a new contact is enrolled into, per lead source (optional).
GHL_WORKFLOW_MEDICARE_CONFIRMATION_ID=
GHL_WORKFLOW_FINAL_EXPENSE_CONFIRMATION_ID=
GHL_WORKFLOW_REVERSE_MTG_CONFIRMATION_ID=
GHL_WORKFLOW_PROBATE_CONFIRMATION_ID=
GHL_WORKFLOW_RECRUITING_CONFIRMATION_ID=
# GHL user ids for assignment/routing (optional).
GHL_ASSIGNED_USER_OWNER_ID=
GHL_ASSIGNED_USER_VA_ID=

# ---- Social Publishing (via GHL Social Planner) ---------------------------
# Live posting requires GHL token+location above AND the social accounts
# connected inside GHL. Paste the connected-account ids here, flip the flags.
SOCIAL_PUBLISHING_ENABLED=false
SOCIAL_MOCK_MODE=true
GHL_SOCIAL_PLANNER_ENABLED=false
GHL_SOCIAL_FACEBOOK_ACCOUNT_ID=
GHL_SOCIAL_INSTAGRAM_ACCOUNT_ID=
GHL_SOCIAL_LINKEDIN_ACCOUNT_ID=
GHL_SOCIAL_GOOGLE_BUSINESS_PROFILE_ID=
# Legacy direct-API fallbacks (used only if the GHL_SOCIAL_* one above is blank):
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCOUNT_ID=
LINKEDIN_ORGANIZATION_ID=

# ---- WordPress (Resource Center publishing) -------------------------------
# Mock until the client's site + Application Password are added. To go live:
# set WORDPRESS_ENABLED=true, WORDPRESS_MOCK_MODE=false and fill the values.
WORDPRESS_ENABLED=false
WORDPRESS_MOCK_MODE=true
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=
WORDPRESS_DEFAULT_AUTHOR_ID=
WORDPRESS_RESOURCE_CATEGORY_ID=
WORDPRESS_STATUS_DEFAULT=draft

# ---- Email ----------------------------------------------------------------
EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=leads@goldwaycapital.com
FROM_NAME=Goldway Capital
M365_SHARED_MAILBOX=leads@goldwaycapital.com
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=

# ---- Analytics / SEO ------------------------------------------------------
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
GOOGLE_SEARCH_CONSOLE_VERIFICATION=
GOOGLE_TAG_MANAGER_ID=

# ---- Spam protection ------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ---- Compliance -----------------------------------------------------------
COMPLIANCE_REVIEW_REQUIRED=true
BLOCK_HEALTH_INFO_FIELDS=true

# ---- API server -----------------------------------------------------------
API_PORT=4000
