# =============================================================================
# Goldway Capital — FRONTEND (public marketing website, Next.js). Copy to .env.local
# This app is fully anonymous. It calls the backend API server-side only.
# =============================================================================

# Base URL of the backend app (admin panel + API). Server-side only — not public.
BACKEND_API_URL=http://localhost:3001

# Shared secret attached to lead submissions. MUST match the backend's
# LEAD_API_INGEST_KEY. Stays on the server (never exposed to the browser).
LEAD_API_INGEST_KEY=change-me-shared-with-website

# Optional: analytics / spam-protection public keys for the website.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
