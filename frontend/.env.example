# =============================================================================
# Goldway Capital — ADMIN PANEL FRONTEND (admin.goldwaycapital.com). Copy to .env.local
# Admin UI only: no database, no Prisma, no GHL token, no JWT secret.
# Every data call goes to the backend API deployment (server-side).
# =============================================================================

# Backend API base URL used by server actions / server components (private).
# This is what login and all admin data calls hit. Set it on Netlify.
# Local dev: the backend runs on port 3001.
BACKEND_API_URL=http://localhost:3001

# Public fallback, used only when BACKEND_API_URL is unset (or by client code).
# Safe to expose (it is just a URL, no secret).
NEXT_PUBLIC_API_URL=http://localhost:3001
