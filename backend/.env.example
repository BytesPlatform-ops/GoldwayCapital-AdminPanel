# =============================================================================
# Goldway Capital — BACKEND API (api.goldwaycapital.com). Copy to .env.
# API only: auth, admin APIs, WordPress lead intake, GHL integration, Prisma DB,
# webhooks. NONE of these values may ever be exposed to the frontend.
# Defaults keep GHL / WordPress / social / email in MOCK mode — safe to run as-is.
# =============================================================================

# ---- Database (PostgreSQL) ------------------------------------------------
# DATABASE_URL = runtime connection (pooler OK), DIRECT_URL = migrations.
DATABASE_URL=
DIRECT_URL=

# ---- Auth -----------------------------------------------------------------
JWT_SECRET=
COOKIE_SECRET=
# Shared secret the WordPress site sends with form posts (x-goldway-key header).
# Optional — when unset, /api/public/leads/submit accepts unauthenticated posts.
LEAD_API_INGEST_KEY=

# ---- Allowed browser origins (CORS — no wildcard in production) ------------
FRONTEND_ORIGIN=https://admin.goldwaycapital.com
WORDPRESS_ORIGIN=https://goldwaycapital.com

# ---- GoHighLevel CRM ------------------------------------------------------
GHL_ENABLED=false
GHL_MOCK_MODE=true
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=

# Per-vertical pipelines + stage ids. Each falls back to the legacy
# single-pipeline vars (GHL_PIPELINE_ID / GHL_STAGE_<STAGE>_ID) when unset.
GHL_PIPELINE_MEDICARE_ID=
GHL_STAGE_MEDICARE_NEW_ID=
GHL_STAGE_MEDICARE_CONTACTED_ID=
GHL_STAGE_MEDICARE_APPOINTMENT_SET_ID=
GHL_STAGE_MEDICARE_CLOSED_ID=

GHL_PIPELINE_FINAL_EXPENSE_ID=
GHL_STAGE_FINAL_EXPENSE_NEW_ID=
GHL_STAGE_FINAL_EXPENSE_CONTACTED_ID=
GHL_STAGE_FINAL_EXPENSE_APPOINTMENT_SET_ID=
GHL_STAGE_FINAL_EXPENSE_CLOSED_ID=

GHL_PIPELINE_REVERSE_MTG_ID=
GHL_STAGE_REVERSE_MTG_NEW_ID=
GHL_STAGE_REVERSE_MTG_CONTACTED_ID=
GHL_STAGE_REVERSE_MTG_APPOINTMENT_SET_ID=
GHL_STAGE_REVERSE_MTG_CLOSED_ID=

GHL_PIPELINE_PROBATE_ID=
GHL_STAGE_PROBATE_NEW_ID=
GHL_STAGE_PROBATE_CONTACTED_ID=
GHL_STAGE_PROBATE_APPOINTMENT_SET_ID=
GHL_STAGE_PROBATE_CLOSED_ID=

GHL_PIPELINE_RECRUITING_ID=
GHL_STAGE_RECRUITING_NEW_ID=
GHL_STAGE_RECRUITING_CONTACTED_ID=
GHL_STAGE_RECRUITING_APPOINTMENT_SET_ID=
GHL_STAGE_RECRUITING_CLOSED_ID=

# Legacy single-pipeline fallback (used when a per-vertical var above is blank).
GHL_PIPELINE_ID=
GHL_STAGE_NEW_ID=
GHL_STAGE_CONTACTED_ID=
GHL_STAGE_APPOINTMENT_SET_ID=
GHL_STAGE_CLOSED_ID=

# GHL custom fields: GHL_CF_<NAME>_ID = the GHL field id, GHL_CF_<NAME>_KEY =
# our payload key it maps from (defaults to lowercased <NAME>). Payload keys
# sent today: service_interest, form_name, consent_given, utm_source, soa_status.
GHL_CF_SERVICE_INTEREST_ID=
GHL_CF_SERVICE_INTEREST_KEY=service_interest
GHL_CF_FORM_NAME_ID=
GHL_CF_FORM_NAME_KEY=form_name
GHL_CF_CONSENT_GIVEN_ID=
GHL_CF_CONSENT_GIVEN_KEY=consent_given
GHL_CF_UTM_SOURCE_ID=
GHL_CF_UTM_SOURCE_KEY=utm_source
GHL_CF_SOA_STATUS_ID=
GHL_CF_SOA_STATUS_KEY=soa_status

# Contact tags applied per vertical (lowercase).
GHL_TAG_MEDICARE=medicare
GHL_TAG_FINAL_EXPENSE=final-expense
GHL_TAG_REVERSE_MTG=reverse-mtg
GHL_TAG_PROBATE=probate
GHL_TAG_RECRUITING=recruiting

# Confirmation workflow a new contact is enrolled into, per lead source (optional).
GHL_WORKFLOW_MEDICARE_CONFIRMATION_ID=
GHL_WORKFLOW_FINAL_EXPENSE_CONFIRMATION_ID=
GHL_WORKFLOW_REVERSE_MTG_CONFIRMATION_ID=
GHL_WORKFLOW_PROBATE_CONFIRMATION_ID=
GHL_WORKFLOW_RECRUITING_CONFIRMATION_ID=
# GHL user ids for assignment/routing (optional).
GHL_ASSIGNED_USER_OWNER_ID=
GHL_ASSIGNED_USER_VA_ID=

# ---- Calendar booking links (returned to WordPress after lead submit) ------
MEDICARE_CALENDAR_LINK=
FINAL_EXPENSE_CALENDAR_LINK=
REVERSE_MORTGAGE_CALENDAR_LINK=
PROBATE_CALENDAR_LINK=
RECRUITING_CALENDAR_LINK=

# ---- Social Publishing (via GHL Social Planner) ---------------------------
SOCIAL_PUBLISHING_ENABLED=false
SOCIAL_MOCK_MODE=true
GHL_SOCIAL_PLANNER_ENABLED=false
GHL_SOCIAL_FACEBOOK_ACCOUNT_ID=
GHL_SOCIAL_INSTAGRAM_ACCOUNT_ID=
GHL_SOCIAL_LINKEDIN_ACCOUNT_ID=
GHL_SOCIAL_GOOGLE_BUSINESS_PROFILE_ID=

# ---- WordPress (Resource Center publishing via REST API) -------------------
WORDPRESS_ENABLED=false
WORDPRESS_MOCK_MODE=true
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=
WORDPRESS_DEFAULT_AUTHOR_ID=
WORDPRESS_RESOURCE_CATEGORY_ID=
WORDPRESS_STATUS_DEFAULT=draft

# ---- Email ----------------------------------------------------------------
EMAIL_PROVIDER=mock
FROM_EMAIL=leads@goldwaycapital.com
FROM_NAME=Goldway Capital
M365_SHARED_MAILBOX=leads@goldwaycapital.com

# ---- Compliance -----------------------------------------------------------
COMPLIANCE_REVIEW_REQUIRED=true
BLOCK_HEALTH_INFO_FIELDS=true
