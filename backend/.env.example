# =============================================================================
# Goldway Capital — BACKEND API (api.goldwaycapital.com). Copy to .env.
# API only: auth, admin APIs, WordPress lead intake, GHL integration, Prisma DB,
# webhooks. NONE of these values may ever be exposed to the frontend/WordPress.
# Defaults keep GHL / WordPress / social / email in MOCK mode — safe to run as-is.
# Placeholders only — never commit real secrets.
# =============================================================================

# ---- App URLs -------------------------------------------------------------
APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ---- Allowed browser origins (CORS — read by src/middleware.ts) ------------
# No wildcard in production. Server-to-server callers send no Origin and are unaffected.
FRONTEND_ORIGIN=https://admin.goldwaycapital.com
WORDPRESS_ORIGIN=https://goldwaycapital.com

# ---- Database (PostgreSQL) ------------------------------------------------
# DATABASE_URL = runtime connection (pooler OK), DIRECT_URL = migrations.
DATABASE_URL=
DIRECT_URL=

# ---- Auth -----------------------------------------------------------------
JWT_SECRET=
# Shared secret the WordPress site sends with form posts (x-goldway-key header).
# Optional — when unset, /api/public/leads/submit accepts unauthenticated posts.
LEAD_API_INGEST_KEY=

# ---- GoHighLevel CRM ------------------------------------------------------
# MOCK is the default. To go live: GHL_ENABLED=true + GHL_MOCK_MODE=false, then
# use the Test button on the frontend Integrations page. The private integration
# token stays server-side only — never returned, logged, or sent to the client.
GHL_ENABLED=false
GHL_MOCK_MODE=true
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=

# ---- Pipelines & stages, per lead source ----------------------------------
# Each per-vertical var falls back to the legacy single-pipeline vars below.
GHL_PIPELINE_MEDICARE_ID=
GHL_STAGE_MEDICARE_NEW_ID=
GHL_STAGE_MEDICARE_CONTACTED_ID=
GHL_STAGE_MEDICARE_APPOINTMENT_SET_ID=
GHL_STAGE_MEDICARE_CLOSED_ID=

GHL_PIPELINE_FINAL_EXPENSE_ID=
GHL_STAGE_FINAL_EXPENSE_NEW_ID=
GHL_STAGE_FINAL_EXPENSE_CONTACTED_ID=
GHL_STAGE_FINAL_EXPENSE_APPOINTMENT_SET_ID=
GHL_STAGE_FINAL_EXPENSE_CLOSED_ID=

GHL_PIPELINE_REVERSE_MTG_ID=
GHL_STAGE_REVERSE_MTG_NEW_ID=
GHL_STAGE_REVERSE_MTG_CONTACTED_ID=
GHL_STAGE_REVERSE_MTG_APPOINTMENT_SET_ID=
GHL_STAGE_REVERSE_MTG_CLOSED_ID=

GHL_PIPELINE_PROBATE_ID=
GHL_STAGE_PROBATE_NEW_ID=
GHL_STAGE_PROBATE_CONTACTED_ID=
GHL_STAGE_PROBATE_APPOINTMENT_SET_ID=
GHL_STAGE_PROBATE_CLOSED_ID=

GHL_PIPELINE_RECRUITING_ID=
GHL_STAGE_RECRUITING_NEW_ID=
GHL_STAGE_RECRUITING_CONTACTED_ID=
GHL_STAGE_RECRUITING_APPOINTMENT_SET_ID=
GHL_STAGE_RECRUITING_CLOSED_ID=

# Legacy single-pipeline fallback (used when a per-vertical var above is blank).
GHL_PIPELINE_ID=
GHL_STAGE_NEW_ID=
GHL_STAGE_CONTACTED_ID=
GHL_STAGE_APPOINTMENT_SET_ID=
GHL_STAGE_CLOSED_ID=

# ---- GHL Custom Fields -----------------------------------------------------
# GHL_CF_<NAME>_ID = the GHL field id; GHL_CF_<NAME>_KEY = the field key it maps
# from (the value GHL returns as `fieldKey`, e.g. contact.lead_source).
# Common / hidden fields
GHL_CF_LEAD_SOURCE_ID=
GHL_CF_LEAD_SOURCE_KEY=contact.lead_source
GHL_CF_CAMPAIGN_ID=
GHL_CF_CAMPAIGN_KEY=contact.campaign
GHL_CF_LANDING_PAGE_URL_ID=
GHL_CF_LANDING_PAGE_URL_KEY=contact.landing_page_url
GHL_CF_SUBMISSION_DATE_TIME_ID=
GHL_CF_SUBMISSION_DATE_TIME_KEY=contact.submission_date_and_time
GHL_CF_BEST_TIME_TO_CALL_ID=
GHL_CF_BEST_TIME_TO_CALL_KEY=contact.best_time_to_call
GHL_CF_EMAIL_CONSENT_ID=
GHL_CF_EMAIL_CONSENT_KEY=contact.email_consent
GHL_CF_SMS_CONSENT_ID=
GHL_CF_SMS_CONSENT_KEY=contact.sms_consent
GHL_CF_TCPA_CONSENT_TIMESTAMP_ID=
GHL_CF_TCPA_CONSENT_TIMESTAMP_KEY=contact.tcpa_consent_timestamp

# Medicare fields (only "currently enrolled in Medicare?" Yes/No — no health data)
GHL_CF_COUNTY_ID=
GHL_CF_COUNTY_KEY=contact.county
GHL_CF_TURNING_65_ID=
GHL_CF_TURNING_65_KEY=contact.turning_65
GHL_CF_CURRENTLY_ENROLLED_MEDICARE_ID=
GHL_CF_CURRENTLY_ENROLLED_MEDICARE_KEY=contact.currently_enrolled_in_medicare
GHL_CF_MEDICARE_HELP_WITH_ID=
GHL_CF_MEDICARE_HELP_WITH_KEY=contact.i_need_help_with
GHL_CF_MEDICARE_BIGGEST_QUESTION_ID=
GHL_CF_MEDICARE_BIGGEST_QUESTION_KEY=contact.medicare_biggest_question

# Final Expense fields
GHL_CF_AGE_RANGE_ID=
GHL_CF_AGE_RANGE_KEY=contact.age_range
GHL_CF_FINAL_EXPENSE_COVERAGE_ID=
GHL_CF_FINAL_EXPENSE_COVERAGE_KEY=contact.currently_have_lifefinal_expense_coverage
GHL_CF_FINAL_EXPENSE_MOST_IMPORTANT_ID=
GHL_CF_FINAL_EXPENSE_MOST_IMPORTANT_KEY=contact.final_expense_most_important

# Reverse Mortgage fields
GHL_CF_AGE_62_OR_OLDER_ID=
GHL_CF_AGE_62_OR_OLDER_KEY=contact.are_you_62_or_older
GHL_CF_PRIMARY_RESIDENCE_ID=
GHL_CF_PRIMARY_RESIDENCE_KEY=contact.is_this_your_primary_residence
GHL_CF_ESTIMATED_HOME_VALUE_ID=
GHL_CF_ESTIMATED_HOME_VALUE_KEY=contact.estimated_home_value
GHL_CF_ESTIMATED_MORTGAGE_BALANCE_ID=
GHL_CF_ESTIMATED_MORTGAGE_BALANCE_KEY=contact.estimated_mortgage_balance
GHL_CF_REVERSE_MTG_MAIN_GOAL_ID=
GHL_CF_REVERSE_MTG_MAIN_GOAL_KEY=contact.reverse_mortgage_main_goal
GHL_CF_REVERSE_MTG_BIGGEST_CONCERN_ID=
GHL_CF_REVERSE_MTG_BIGGEST_CONCERN_KEY=contact.reverse_mortgage_biggest_concern

# Probate / Senior Real Estate fields
GHL_CF_STATE_ID=
GHL_CF_STATE_KEY=contact.state
GHL_CF_REAL_ESTATE_SITUATION_ID=
GHL_CF_REAL_ESTATE_SITUATION_KEY=contact.real_estate_situation
GHL_CF_EXECUTOR_OR_HEIR_ID=
GHL_CF_EXECUTOR_OR_HEIR_KEY=contact.executor_or_heir
GHL_CF_REAL_ESTATE_TIMELINE_ID=
GHL_CF_REAL_ESTATE_TIMELINE_KEY=contact.real_estate_timeline
GHL_CF_REAL_ESTATE_DETAILS_ID=
GHL_CF_REAL_ESTATE_DETAILS_KEY=contact.real_estate_situation_details

# Recruiting fields
GHL_CF_STATE_OF_RESIDENCE_ID=
GHL_CF_STATE_OF_RESIDENCE_KEY=contact.state_of_residence
GHL_CF_INSURANCE_LICENSE_ID=
GHL_CF_INSURANCE_LICENSE_KEY=contact.currently_hold_insurance_license
GHL_CF_LICENSED_LINES_ID=
GHL_CF_LICENSED_LINES_KEY=contact.licensed_lines
GHL_CF_AHIP_CERTIFIED_ID=
GHL_CF_AHIP_CERTIFIED_KEY=contact.ahip_certified_current_plan_year
GHL_CF_RECRUITING_BACKGROUND_ID=
GHL_CF_RECRUITING_BACKGROUND_KEY=contact.recruiting_background

# ---- Contact tags applied per vertical (lowercase) -------------------------
GHL_TAG_MEDICARE=medicare
GHL_TAG_FINAL_EXPENSE=final-expense
GHL_TAG_REVERSE_MTG=reverse-mtg
GHL_TAG_PROBATE=probate
GHL_TAG_RECRUITING=recruiting
GHL_TAG_CONTACT=contact

# ---- Contact form custom fields (6th form: general "Contact") --------------
# General contact form. Synced to GHL as a tagged contact (GHL_TAG_CONTACT) with
# these custom fields — no dedicated pipeline/calendar. The "Contact Form
# Submitted" GHL workflow is triggered off the "contact" tag.
GHL_CF_SERVICE_INTEREST_ID=
GHL_CF_SERVICE_INTEREST_KEY=contact.service_interest
GHL_CF_PREFERRED_CONTACT_METHOD_ID=
GHL_CF_PREFERRED_CONTACT_METHOD_KEY=contact.preferred_contact_method
GHL_CF_BEST_TIME_TO_CONTACT_ID=
GHL_CF_BEST_TIME_TO_CONTACT_KEY=contact.best_time_to_contact
GHL_CF_CONTACT_MESSAGE_ID=
GHL_CF_CONTACT_MESSAGE_KEY=contact.contact_message

# ---- Confirmation workflows + assignment (optional) ------------------------
GHL_WORKFLOW_MEDICARE_CONFIRMATION_ID=
GHL_WORKFLOW_FINAL_EXPENSE_CONFIRMATION_ID=
GHL_WORKFLOW_REVERSE_MTG_CONFIRMATION_ID=
GHL_WORKFLOW_PROBATE_CONFIRMATION_ID=
GHL_WORKFLOW_RECRUITING_CONFIRMATION_ID=
GHL_ASSIGNED_USER_OWNER_ID=
GHL_ASSIGNED_USER_VA_ID=

# ---- GHL Calendar ids + slugs ---------------------------------------------
GHL_CALENDAR_MEDICARE_ID=
GHL_CALENDAR_MEDICARE_SLUG=
GHL_CALENDAR_FINAL_EXPENSE_ID=
GHL_CALENDAR_FINAL_EXPENSE_SLUG=
GHL_CALENDAR_REVERSE_MTG_ID=
GHL_CALENDAR_REVERSE_MTG_SLUG=
GHL_CALENDAR_PROBATE_ID=
GHL_CALENDAR_PROBATE_SLUG=
GHL_CALENDAR_RECRUITING_ID=
GHL_CALENDAR_RECRUITING_SLUG=

# ---- Calendar booking links (returned to WordPress after lead submit) ------
MEDICARE_CALENDAR_LINK=
FINAL_EXPENSE_CALENDAR_LINK=
REVERSE_MORTGAGE_CALENDAR_LINK=
PROBATE_CALENDAR_LINK=
RECRUITING_CALENDAR_LINK=

# ---- Social Publishing (via GHL Social Planner) ---------------------------
SOCIAL_PUBLISHING_ENABLED=false
SOCIAL_MOCK_MODE=true
GHL_SOCIAL_PLANNER_ENABLED=false
GHL_SOCIAL_FACEBOOK_ACCOUNT_ID=
GHL_SOCIAL_INSTAGRAM_ACCOUNT_ID=
GHL_SOCIAL_LINKEDIN_ACCOUNT_ID=
GHL_SOCIAL_GOOGLE_BUSINESS_PROFILE_ID=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCOUNT_ID=
LINKEDIN_ORGANIZATION_ID=

# ---- WordPress (Resource Center publishing via REST API) -------------------
WORDPRESS_ENABLED=false
WORDPRESS_MOCK_MODE=true
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=
WORDPRESS_DEFAULT_AUTHOR_ID=
WORDPRESS_RESOURCE_CATEGORY_ID=
WORDPRESS_STATUS_DEFAULT=draft

# ---- Email ----------------------------------------------------------------
# Confirmation emails are handled by GHL workflows in production; the backend
# email service defaults to a mock provider. Only the shared mailbox is read.
EMAIL_PROVIDER=mock
FROM_EMAIL=leads@goldwaycapital.com
FROM_NAME=Goldway Capital
M365_SHARED_MAILBOX=leads@goldwaycapital.com

# ---- Compliance -----------------------------------------------------------
COMPLIANCE_REVIEW_REQUIRED=true
BLOCK_HEALTH_INFO_FIELDS=true
